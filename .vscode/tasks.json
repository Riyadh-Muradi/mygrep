{
	"tasks": [
		{
			"type": "cppbuild",
			"label": "C/C++: g++.exe build active file",
			"command": "C:/MinGW/bin/g++.exe",
			"args": [
				"-fdiagnostics-color=always",
				"-g",
				"${file}",
				"-o",
				"${fileDirname}\\${fileBasenameNoExtension}.exe"
			],
			"options": {
				"cwd": "C:/MinGW/bin"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"detail": "Task generated by Debugger."
		},
		{
			"label": "build mygrep",
			"type": "shell",
			"command": "C:/MinGW/bin/g++.exe",
			"args": [
				"-fdiagnostics-color=always",
				"-g",
				"main.cpp",
				"-o",
				"main.exe"
			],
			"isBackground": false,
			"problemMatcher": [
				"$gcc"
			],
			"group": "build"
		},
		{
			"label": "build mygrep exe",
			"type": "shell",
			"command": "C:/MinGW/bin/g++.exe",
			"args": [
				"-fdiagnostics-color=always",
				"-g",
				"main.cpp",
				"-o",
				"mygrep.exe"
			],
			"isBackground": false,
			"problemMatcher": [
				"$gcc"
			]
		},
		{
			"label": "run increment2 sample",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"mygrep.exe following man_grep_plain_ASCII.txt"
			],
			"isBackground": false
		},
		{
			"label": "run increment3 sample",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"mygrep.exe -olo following man_grep_plain_ASCII.txt"
			],
			"isBackground": false
		},
		{
			"label": "run increment4 case-insensitive",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"mygrep.exe -oi folloWING man_grep_plain_ASCII.txt"
			],
			"isBackground": false
		},
		{
			"label": "run increment4 all-options",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"mygrep.exe -olori folloWING man_grep_plain_ASCII.txt"
			],
			"isBackground": false
		},
		{
			"label": "run missing file exception",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"mygrep.exe -olori folloWING man_grep_plain_ASCII_missing.txt"
			],
			"isBackground": false
		}
	],
	"version": "2.0.0"
}